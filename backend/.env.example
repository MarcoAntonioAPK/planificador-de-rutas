# Genera este valor con: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=replace-with-a-generated-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Incluye el puerto exacto desde el que sirves el frontend. Live Server suele usar 5500.
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5500,http://127.0.0.1:5500

DB_NAME=routeflow
DB_USER=routeflow
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432

DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=no-reply@planificadorderutas.local
FRONTEND_URL=http://localhost:5500
