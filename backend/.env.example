DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:8000

# Usa "sqlite" para empezar sin instalar un servidor de base de datos.
# Para PostgreSQL cambia el valor y completa las variables siguientes.
DB_ENGINE=sqlite
DB_NAME=routeflow
DB_USER=routeflow
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432
